# Supabase project URL — copy from Supabase dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-new-project.supabase.co

# Supabase anon (public) key — same Settings → API page. Safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site origin used in absolute URLs (OG images, magic-link redirects).
# Locally: http://localhost:3000. In Vercel: set to your prod URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
